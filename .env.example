# Copy this file to .env and fill in the values for your LLM provider.
# Optional aliases used by llm_runtime.py.
# Use these instead of OPENAI_* if you are connecting to another
# OpenAI-compatible server such as Ollama, vLLM, or LM Studio.
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.xah.io/v1
